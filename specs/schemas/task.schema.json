{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FactoryOS Task",
  "type": "object",
  "required": ["title", "description", "project_path", "phase", "risk"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "project_path": {
      "type": "string",
      "pattern": "^<CODE_ROOT>/"
    },
    "phase": {
      "type": "string",
      "enum": ["docs", "spec", "implement", "fix", "validate", "review"]
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "validation_commands": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "additionalProperties": false
}
