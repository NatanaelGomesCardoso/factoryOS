    ".venv/bin/python -m app.cli codex-capsule-list --limit 5 > <TMP_DIR>/s048-capsule-list.json",
    ".venv/bin/python -m app.cli codex-capsule-inspect --capsule <CAPSULE_PATH> > <TMP_DIR>/s048-capsule-inspect.json",
    "TestClient GET / = 200",
    "git diff --check"
  ],
  "report_path": "reports/minimal-codex-context-capsule-v0-proof.txt",
