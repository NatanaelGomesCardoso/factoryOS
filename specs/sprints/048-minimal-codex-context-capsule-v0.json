{
  "sprint": 48,
  "title": "Minimal Codex Context Capsule V0",
  "status": "done",
  "risk": "medium",
  "executor": "codex",
  "objectives": [
    "Criar cápsula Git mínima para Codex",
    "Inicializar Git dentro da cápsula",
    "Copiar somente arquivos incluídos",
    "Copiar digest recente quando existir",
    "Expor create/list/inspect por CLI"
  ],
  "reuse_first": [
    "codex_context_router",
    "memory_digest",
    "report_index",
    "codex_quiet_runner",
    "cli"
  ],
  "out_of_scope": [
    "alterar ~/.codex/config.toml",
    "mexer no harness global",
    "executar live",
    "copiar reports grandes",
    "usar API paga"
  ],
  "validation": [
    ".venv/bin/python -m py_compile app/*.py",
    ".venv/bin/python -m compileall app > <TMP_DIR>/compileall-s048.txt",
